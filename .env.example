# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# MongoDB Atlas SRV URI (URL-encode special chars in the password).
MONGO_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority"

# Database name used for the users + devices collections.
MONGO_DB="device_registry"

# Secret for signing JWTs. Generate one: openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-string"

# HTTP port the server listens on.
PORT=8080

# --- FCM (push signaling) ---
# Required for the server to push data messages to devices (signaling relay,
# /signal/selfping, notifications). Without this the server runs but /signal*
# returns "FCM not configured on server".
#
# Use a Firebase *service account* JSON for the project (Firebase console →
# Project settings → Service accounts → Generate new private key). Provide it
# either inline as one line of JSON:
#   FCM_SA_JSON='{"type":"service_account","project_id":"my-domain-c0c36",...}'
# or as a path to the JSON file:
#   GOOGLE_APPLICATION_CREDENTIALS="/etc/my-domain/fcm-sa.json"
#
# Optional — defaults to the service account's own project_id:
# FCM_PROJECT_ID="my-domain-c0c36"
